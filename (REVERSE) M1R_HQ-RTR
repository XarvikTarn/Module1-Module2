hostnamectl set-hostname NONAME && exec bash
rm -rf /etc/net/ifaces/enp7s{1,2}
rm -rf /etc/net/ifaces/gre1
rm -rf /etc/net/ifaces/vlan{100,200,999}
sed -i 's/net.ipv4.ip_forward = 1/net.ipv4.ip_forward = 0/' /etc/net/sysctl.conf
sysctl -w net.ipv4.ip_forward=0
sysctl net.ipv4.ip_forward
apt-get remove -y --purge tzdata nftables frr sudo dnsmasq
userdel -r net_admin
systemctl restart network
