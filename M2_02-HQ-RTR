echo "nameserver 77.88.8.8" > /etc/resolv.conf
apt-get update && apt-get install -y chrony
cat <<EOF > /etc/openssh/sshd_config
Port 22
PermitRootLogin yes
Subsystem sftp /usr/lib/openssh/sftp-server
EOF
echo "root:P@ssw0rd" | chpasswd
sed -i 's|172.16.100.1.*|192.168.1.1/27|' /etc/net/ifaces/*/ipv4address 2>/dev/null || true
sed -i 's|172.16.200.1.*|192.168.2.1/28|' /etc/net/ifaces/*/ipv4address 2>/dev/null || true
sed -i 's|172.16.99.1.*|192.168.9.1/29|' /etc/net/ifaces/*/ipv4address 2>/dev/null || true
sed -i 's|10.10.10.1.*|192.168.5.1/30|' /etc/net/ifaces/*/ipv4address 2>/dev/null || true
grep -rl "172.16.100.2" /etc/net/ifaces/ | xargs -r sed -i 's/172.16.100.2/192.168.3.10/'
cat <<EOF > /etc/dnsmasq.conf
port=0
interface=vlan200
dhcp-range=192.168.2.2,192.168.2.14,255.255.255.240,12h
dhcp-host=id:01:11:11:11:11:11,192.168.2.10
dhcp-option=3,192.168.2.1
dhcp-option=6,192.168.3.10
domain=au-team.irpo
EOF
systemctl enable sshd
systemctl restart dnsmasq network frr sshd
sed -i '/pool/d' /etc/chrony.conf
sed -i '/server/d' /etc/chrony.conf
echo "server 172.16.1.1 iburst prefer" >> /etc/chrony.conf
systemctl restart chronyd
sleep 5 && chronyc sources
